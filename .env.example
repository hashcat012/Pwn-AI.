# OPENROUTER_API_KEY: Required for AI features via OpenRouter.
OPENROUTER_API_KEY=MY_OPENROUTER_API_KEY

# Supabase configuration
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# PUTER_AUTH_TOKEN: Required for Gemini via Puter.js
# Visit puter.com, sign up, and get your auth token from Settings
PUTER_AUTH_TOKEN=YOUR_PUTER_AUTH_TOKEN

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000
